---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const projects = allProjects
  .filter((p) => p.data.visible)
  .sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Rawan Aladdin - Projects">
  <header>
    <div>
      <a href="/index.html" class="back-arrow">&#10229;</a>
      <p class="heading-page">My Works</p>
    </div>
    <div class="menu">
      <div class="line"></div>
      <div class="line"></div>
    </div>
    <div class="full-page-menu">
      <ul class="menu-links">
        <li><a href="/index.html">Home&#8599;</a></li>
        <li><a href="/projects.html">Works&#8599;</a></li>
        <li><a href="/about.html">About&#8599;</a></li>
      </ul>
    </div>
  </header>
  <main>
    <div class="flex-grid">
      {projects.map((project) => (
        <a href={project.data.url}>
          <div class="flex-grid-item">
            <div class={`${project.slug}-case`}>
              <p class="identification">{project.data.tags}</p>
              <p class="case-title">{project.data.title}</p>
              <img
                src={project.data.image}
                alt={project.data.imageAlt}
                width="50%"
                height="50%"
              />
            </div>
            <span class="arrow">&#10230;</span>
          </div>
        </a>
      ))}
    </div>
  </main>

  <script type="text/javascript" defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script type="text/javascript" defer src="/js/components/menu.js"></script>
  <script type="text/javascript" defer src="/js/components/gsap-fade.js"></script>
  <script type="text/javascript" defer src="/js/index.js"></script>
</BaseLayout>
