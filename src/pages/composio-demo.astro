---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Composio Demo">
  <div class="container">
    <h1>Composio Agent Demo</h1>

    <section class="demo-section">
      <h2>1. Authorize Gmail</h2>
      <p>First, authorize your Gmail account to allow the agent to send emails.</p>
      <button id="authorize-btn" class="btn">Authorize Gmail</button>
      <div id="auth-result" class="result"></div>
    </section>

    <section class="demo-section">
      <h2>2. Send Email via Agent</h2>
      <p>Enter a prompt for the AI agent to execute (e.g., "Send an email to example@email.com saying hello").</p>
      <textarea
        id="prompt-input"
        placeholder="Send an email to raladdin@my.bcit.ca saying hello"
        rows="4"
      ></textarea>
      <button id="send-btn" class="btn">Execute Query</button>
      <div id="send-result" class="result"></div>
    </section>
  </div>

  <style>
    .container {
      max-width: 800px;
      margin: 2rem auto;
      padding: 0 1rem;
    }

    h1 {
      font-size: 2.5rem;
      margin-bottom: 2rem;
    }

    .demo-section {
      margin-bottom: 3rem;
      padding: 2rem;
      border: 1px solid #e5e7eb;
      border-radius: 0.5rem;
    }

    h2 {
      font-size: 1.5rem;
      margin-bottom: 1rem;
    }

    textarea {
      width: 100%;
      padding: 0.75rem;
      margin: 1rem 0;
      border: 1px solid #d1d5db;
      border-radius: 0.375rem;
      font-family: inherit;
      font-size: 1rem;
    }

    .btn {
      background: #3b82f6;
      color: white;
      padding: 0.75rem 1.5rem;
      border: none;
      border-radius: 0.375rem;
      cursor: pointer;
      font-size: 1rem;
      font-weight: 500;
    }

    .btn:hover {
      background: #2563eb;
    }

    .btn:disabled {
      background: #9ca3af;
      cursor: not-allowed;
    }

    .result {
      margin-top: 1rem;
      padding: 1rem;
      border-radius: 0.375rem;
      min-height: 3rem;
      white-space: pre-wrap;
      word-break: break-word;
    }

    .result.success {
      background: #d1fae5;
      color: #065f46;
    }

    .result.error {
      background: #fee2e2;
      color: #991b1b;
    }

    .result.info {
      background: #dbeafe;
      color: #1e40af;
    }

    .result:empty {
      display: none;
    }
  </style>

  <script>
    const authorizeBtn = document.getElementById('authorize-btn') as HTMLButtonElement;
    const authResult = document.getElementById('auth-result') as HTMLDivElement;
    const sendBtn = document.getElementById('send-btn') as HTMLButtonElement;
    const promptInput = document.getElementById('prompt-input') as HTMLTextAreaElement;
    const sendResult = document.getElementById('send-result') as HTMLDivElement;

    // Authorize Gmail
    authorizeBtn.addEventListener('click', async () => {
      authorizeBtn.disabled = true;
      authResult.className = 'result info';
      authResult.textContent = 'Requesting authorization...';

      try {
        const response = await fetch('/api/composio/authorize', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ appName: 'gmail' }),
        });

        const data = await response.json();

        if (data.success) {
          authResult.className = 'result success';
          authResult.innerHTML = `Authorization URL created successfully!<br><br><a href="${data.redirectUrl}" target="_blank" style="color: inherit; text-decoration: underline;">Click here to authorize Gmail</a>`;
        } else {
          throw new Error(data.error || 'Unknown error');
        }
      } catch (error) {
        authResult.className = 'result error';
        authResult.textContent = `Error: ${error instanceof Error ? error.message : String(error)}`;
      } finally {
        authorizeBtn.disabled = false;
      }
    });

    // Send email via agent
    sendBtn.addEventListener('click', async () => {
      const prompt = promptInput.value.trim();

      if (!prompt) {
        sendResult.className = 'result error';
        sendResult.textContent = 'Please enter a prompt';
        return;
      }

      sendBtn.disabled = true;
      sendResult.className = 'result info';
      sendResult.textContent = 'Executing query...';

      try {
        const response = await fetch('/api/composio/send-email', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ prompt }),
        });

        const data = await response.json();

        if (data.success) {
          sendResult.className = 'result success';
          sendResult.textContent = `Success!\n\nResponses:\n${data.responses.join('\n\n')}`;
        } else {
          throw new Error(data.error || 'Unknown error');
        }
      } catch (error) {
        sendResult.className = 'result error';
        sendResult.textContent = `Error: ${error instanceof Error ? error.message : String(error)}`;
      } finally {
        sendBtn.disabled = false;
      }
    });
  </script>
</BaseLayout>
