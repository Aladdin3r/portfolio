---
import BaseLayout from './BaseLayout.astro';

interface GuideItem {
  id?: string;
  label: string;
  href?: string;
  isButton?: boolean;
}

interface Props {
  title: string;
  pageTitle: string;
  backUrl?: string;
  guide: GuideItem[];
  extraScripts?: string[];
  bodyClass?: string;
}

const {
  title,
  pageTitle,
  backUrl = "/projects.html",
  guide,
  extraScripts = [],
  bodyClass = "",
} = Astro.props;
---
<BaseLayout title={title} bodyClass={bodyClass}>
  <slot name="head" slot="head" />
  <header>
    <div class="header-container">
      <a href={backUrl} class="back-arrow">&#10229;</a>
      <p class="heading-page">{pageTitle}</p>
    </div>
    <div class="menu">
      <div class="line"></div>
      <div class="line"></div>
    </div>
    <div class="full-page-menu">
      <ul class="menu-links">
        <li><a href="/index.html">Home&#8599;</a></li>
        <li><a href="/projects.html">Works&#8599;</a></li>
        <li><a href="/about.html">About&#8599;</a></li>
      </ul>
    </div>
  </header>
  <main>
    <button id="back-to-top" class="back-to-top">&#8593;</button>
    <slot name="sticky" />
    <slot name="preContent" />
    <div class="content">
      <slot />
    </div>
    <nav class="guide">
      <ul>
        {guide.map((item, i) =>
          item.isButton ? (
            <li>
              <a href={item.href} target="_blank" class="button">
                {item.label} &#8599;
              </a>
            </li>
          ) : (
            <li>
              <a
                href={`#${item.id}`}
                class={`guide-link${i === 0 ? ' active' : ''}`}
              >
                {item.label}
              </a>
            </li>
          )
        )}
      </ul>
    </nav>
  </main>

  <script type="text/javascript" defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
  <script type="text/javascript" defer src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
  <script type="text/javascript" defer src="https://cdnjs.cloudflare.com/ajax/libs/lottie-web/5.9.6/lottie.min.js"></script>
  <script type="text/javascript" defer src="/js/components/menu.js"></script>
  <script type="text/javascript" defer src="/js/components/gsap-fade.js"></script>
  {extraScripts.map((src) => (
    <script type="text/javascript" defer src={src}></script>
  ))}
  <script type="text/javascript" defer src="/js/index.js"></script>
</BaseLayout>
