# Composio API Key
# Get your API key from https://app.composio.dev/settings
COMPOSIO_API_KEY=your_composio_api_key_here

# External User ID (can be any unique identifier for your users)
COMPOSIO_EXTERNAL_USER_ID=your_user_id_here

# Callback URL for OAuth flows
COMPOSIO_CALLBACK_URL=http://localhost:4321/api/composio/callback
